# کپی کنید به deploy.config در همان پوشه پروژه روی سرور:
#   cp deploy.config.example deploy.config
#   nano deploy.config
#
# مسیر را با این دستور پیدا کنید:
#   pm2 describe transport-backend
#   bash scripts/detect-server-path.sh

# مسیر کامل ریشه پروژه (جایی که backend/ و frontend/ هست)
# روی FMS-Mihan:
PROJECT_DIR="/home/fms/project"

# شاخه git (خالی = شاخه فعلی)
# GIT_BRANCH="master"

# آیا frontend هم build شود؟ (true/false)
BUILD_FRONTEND=true

# آیا migrationهای اختیاری اجرا شوند؟
RUN_MIGRATIONS=true
