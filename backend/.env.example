# Bale messenger (optional — module disabled if unset)
BALE_BOT_TOKEN=
# آدرس عمومی سرور برای لینک فایل گزارش بله (مثلاً https://movex.mihan.co.ir)
PUBLIC_API_BASE_URL=
# Optional secret header for webhook: X-Bale-Webhook-Secret
BALE_WEBHOOK_SECRET=
# دریافت پیام راننده بدون webhook (پیش‌فرض: فعال اگر false نباشد)
BALE_ENABLE_POLLING=true
